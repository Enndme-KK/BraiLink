# 部署到生产环境前，把本文件复制为 .env，并按真实值替换
# 本地开发可直接 cp .env.example .env，settings.py 已设了开发友好默认值

# ===== 安全（生产强制覆盖）=====
# 用以下命令生成强密钥：
#   python -c "import secrets; print(secrets.token_urlsafe(60))"
SECRET_KEY=请替换成 64 位以上的随机密钥

# 生产环境必须为 False
DEBUG=True

# 生产环境收窄到具体域名（多个用逗号分隔）：api.example.com,www.example.com
ALLOWED_HOSTS=*

# ===== CORS（生产建议关闭通配）=====
# 生产把 CORS_ALLOW_ALL_ORIGINS 改成 False，并在 CORS_ALLOWED_ORIGINS 列出前端来源
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=

# ===== 数据库 =====
# 默认 sqlite3。生产可改 mysql / postgresql
DATABASE_ENGINE=sqlite3
# DATABASE_NAME=brain_tumor_db
# DATABASE_USER=
# DATABASE_PASSWORD=
# DATABASE_HOST=localhost
# DATABASE_PORT=3306

# ===== 外部服务 =====
FLASK_ML_SERVICE_URL=http://localhost:5000
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===== AI / LLM =====
# DeepSeek API (用于 AI 聊天功能)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
